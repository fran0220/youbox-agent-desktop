# deploy/.env.release — 本地发布凭据 (不入 git)
# 复制: cp deploy/.env.release.example deploy/.env.release

# ── 腾讯云 COS ──
COS_SECRET_ID=
COS_SECRET_KEY=

# ── 数据库 (需先开 SSH 隧道: ssh -L 5432:127.0.0.1:5432 jingao -N -f) ──
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_NAME=jacoworks
DB_PASSWORD=

# ── Apple 签名 + 公证 (macOS, 可选 — 证书已在 Keychain 则只需 identity) ──
APPLE_SIGNING_IDENTITY="Developer ID Application: fan Z (9UUWCMKMDH)"
APPLE_ID=
APPLE_TEAM_ID=
APPLE_APP_SPECIFIC_PASSWORD=
